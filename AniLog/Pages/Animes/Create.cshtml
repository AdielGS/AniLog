@page
@model AniLog.Pages.Animes.CreateModel
@{
    ViewData["Title"] = "Adicionar Novo";
}

<div class="container mt-5" style="max-width: 550px;">
    <div class="card shadow-sm p-4">
        <h2 class="fw-bold mb-1">Adicionar ao Meu Log</h2>
        <p class="text-muted small mb-4">Digite o nome e selecione a opção correta da lista.</p>

        @if (!ModelState.IsValid && ModelState.ContainsKey("Duplicado"))
        {
            <div class="alert alert-danger text-sm">@ModelState["Duplicado"].Errors[0].ErrorMessage</div>
        }

        <form method="post">
            <div class="mb-3 position-relative">
                <label class="form-label fw-semibold">Título do Anime ou Filme</label>
                <input type="text" asp-for="Anime.Titulo" id="tituloAnime" class="form-control" placeholder="Busque o nome em inglês/romaji..." autocomplete="off" oninput="buscarSugesoes()" required />

                <ul id="listaSugestoes" class="list-group position-absolute w-100 shadow-sm" style="z-index: 1000; max-height: 250px; overflow-y: auto; display: none;"></ul>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label fw-semibold">Status</label>
                    <select asp-for="Anime.Status" class="form-select">
                        <option value="Assistido">🍿 Já Assistido</option>
                        <option value="Quero Assistir">📌 Quero Assistir</option>
                    </select>
                </div>

                <div class="col-md-6 mb-3">
                    <label class="form-label fw-semibold">Sua Nota</label>
                    <div class="rating">
                        <input type="radio" asp-for="Anime.Nota" value="5" id="star5" /><label for="star5">★</label>
                        <input type="radio" asp-for="Anime.Nota" value="4" id="star4" /><label for="star4">★</label>
                        <input type="radio" asp-for="Anime.Nota" value="3" id="star3" /><label for="star3">★</label>
                        <input type="radio" asp-for="Anime.Nota" value="2" id="star2" /><label for="star2">★</label>
                        <input type="radio" asp-for="Anime.Nota" value="1" id="star1" /><label for="star1">★</label>
                    </div>
                </div>
            </div>

            <input type="hidden" asp-for="Anime.ImagemUrl" id="imagemUrl" required />

            <div class="mb-4 text-center bg-light p-3 rounded-3 border">
                <img id="previewCapa" src="https://via.placeholder.com/120x170?text=Sem+Capa" alt="Preview" class="img-capa" style="height: 170px; width: 120px;" />
            </div>

            <button type="submit" id="btnSalvar" class="btn btn-primary w-100 py-2 fs-6 shadow-sm" disabled>Selecionar um anime da lista para salvar</button>
        </form>
    </div>
</div>

<style>
    .rating {
        display: flex;
        flex-direction: row-reverse;
        justify-content: flex-end;
    }

        .rating input {
            display: none;
        }

        .rating label {
            font-size: 1.8rem;
            color: #e2e8f0;
            cursor: pointer;
        }

            .rating input:checked ~ label, .rating label:hover, .rating label:hover ~ label {
                color: #ffca08;
            }

    #listaSugestoes .list-group-item {
        cursor: pointer;
    }

        #listaSugestoes .list-group-item:hover {
            background-color: #f8fafc;
        }
</style>

<script>
    let timeout = null;

    function buscarSugesoes() {
        clearTimeout(timeout);
        const query = document.getElementById('tituloAnime').value.trim();
        const lista = document.getElementById('listaSugestoes');

        if (query.length < 3) {
            lista.style.display = 'none';
            document.getElementById('btnSalvar').disabled = true;
            return;
        }

        // Aguarda 400ms após o usuário parar de digitar para não estourar o limite da API externa
        timeout = setTimeout(async () => {
            try {
                const response = await fetch(`https://api.jikan.moe/v4/anime?q=${encodeURIComponent(query)}&limit=5`);
                const result = await response.json();

                lista.innerHTML = '';
                if (result.data && result.data.length > 0) {
                    result.data.forEach(anime => {
                        const li = document.createElement('li');
                        li.className = 'list-group-item d-flex align-items-center gap-2';
                        li.innerHTML = `<img src="${anime.images.jpg.small_image_url}" style="width:35px; height:50px; object-fit:cover;" class="rounded"/> <span>${anime.title}</span>`;

                        // Ao clicar na sugestão da lista
                        li.onclick = () => {
                            document.getElementById('tituloAnime').value = anime.title;
                            document.getElementById('previewCapa').src = anime.images.jpg.image_url;
                            document.getElementById('imagemUrl').value = anime.images.jpg.image_url;
                            lista.style.display = 'none';

                            // Libera o botão salvar já que o nome é válido
                            document.getElementById('btnSalvar').disabled = false;
                            document.getElementById('btnSalvar').innerText = "Salvar no Registro";
                        };
                        lista.appendChild(li);
                    });
                    lista.style.display = 'block';
                }
            } catch (e) { console.error(e); }
        }, 400);
    }
</script>