@page "{id:int}"
@model AniLog.Pages.Animes.EditModel
@{
    ViewData["Title"] = "Editar Registro";
}

<div class="container mt-5" style="max-width: 500px;">
    <div class="card shadow-sm p-4">
        <h3 class="fw-bold mb-4">Atualizar Status</h3>

        <form method="post">
            <input type="hidden" asp-for="Anime.Id" />
            <input type="hidden" asp-for="Anime.Titulo" />
            <input type="hidden" asp-for="Anime.ImagemUrl" />
            <input type="hidden" asp-for="Anime.UsuarioId" />

            <div class="text-center mb-4">
                <img src="@Model.Anime.ImagemUrl" class="img-capa mb-2" style="height: 180px; width: 125px;" />
                <h5 class="fw-bold">@Model.Anime.Titulo</h5>
            </div>

            <div class="mb-3">
                <label class="form-label fw-semibold">Alterar Status</label>
                <select asp-for="Anime.Status" class="form-select">
                    <option value="Assistido">🍿 Já Assistido</option>
                    <option value="Quero Assistir">📌 Quero Assistir</option>
                </select>
            </div>

            <div class="mb-4">
                <label class="form-label fw-semibold">Sua Nota</label>
                <div class="rating">
                    <input type="radio" asp-for="Anime.Nota" value="5" id="star5" /><label for="star5">★</label>
                    <input type="radio" asp-for="Anime.Nota" value="4" id="star4" /><label for="star4">★</label>
                    <input type="radio" asp-for="Anime.Nota" value="3" id="star3" /><label for="star3">★</label>
                    <input type="radio" asp-for="Anime.Nota" value="2" id="star2" /><label for="star2">★</label>
                    <input type="radio" asp-for="Anime.Nota" value="1" id="star1" /><label for="star1">★</label>
                </div>
            </div>

            <div class="d-flex gap-2">
                <a asp-page="/Index" class="btn btn-light w-50 border">Cancelar</a>
                <button type="submit" class="btn btn-primary w-50">Salvar Mudanças</button>
            </div>
        </form>
    </div>
</div>

<style>
    .rating { display: flex; flex-direction: row-reverse; justify-content: flex-end; }
    .rating input { display: none; }
    .rating label { font-size: 2rem; color: #e2e8f0; cursor: pointer; }
    .rating input:checked ~ label, .rating label:hover, .rating label:hover ~ label { color: #ffca08; }
</style>