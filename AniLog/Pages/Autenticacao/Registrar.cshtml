@page
@model AniLog.Pages.Autenticacao.RegistrarModel
@{
    ViewData["Title"] = "Criar Conta";
}

<div class="container mt-5" style="max-width: 450px;">
    <div class="card shadow-sm p-4">
        <h3 class="fw-bold mb-1">Criar Conta</h3>
        <p class="text-muted small mb-4">Registe-se para iniciar o seu catálogo de mídias.</p>

        @if (!string.IsNullOrEmpty(Model.MensagemErro))
        {
            <div class="alert alert-danger py-2 text-sm">@Model.MensagemErro</div>
        }

        <form method="post">
            <div class="mb-3">
                <label class="form-label fw-semibold">Nome Completo</label>
                <input type="text" asp-for="Input.Nome" class="form-control" required />
            </div>
            <div class="mb-3">
                <label class="form-label fw-semibold">E-mail</label>
                <input type="email" asp-for="Input.Email" class="form-control" required />
            </div>
            <div class="mb-3">
                <label class="form-label fw-semibold">Senha</label>
                <input type="password" asp-for="Input.Senha" class="form-control" required />
            </div>
            <button type="submit" class="btn btn-primary w-100 py-2 shadow-sm mb-3">Concluir Registo</button>
            <div class="text-center">
                <a asp-page="/Autenticacao/Login" class="text-decoration-none small text-muted">Já tem uma conta? Entre aqui</a>
            </div>
        </form>
    </div>
</div>